<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="org.esupportail.smsu.dao.beans">
    <class name="ToContact" table="to_contact" lazy="false">
        <composite-id>
            <key-many-to-one name="Contact" class="Contact" column="CONTACT_ID"/>
            <key-many-to-one name="Message" class="Message" column="MSG_ID"/>
        </composite-id>
    </class>
</hibernate-mapping>
